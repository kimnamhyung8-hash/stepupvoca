    };

    const getResult = () => {
        const ratio = quizWords.length > 0 ? correctCount / quizWords.length : 0;
        if (ratio <= 0.2) return { level: "A1", label: lang === 'ko' ? "?ģļ¼Ė?? : "Beginner", emoji: "?ī▒", color: "from-blue-400 to-blue-600", startLvl: 1 };
        if (ratio <= 0.4) return { level: "A2", label: lang === 'ko' ? "ņ┤łĻĖē?? : "Elementary", emoji: "?ī┐", color: "from-sky-400 to-sky-600", startLvl: 10 };
