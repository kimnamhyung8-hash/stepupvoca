        if (ratio <= 0.8) return { level: "B2", label: lang === 'ko' ? "ņżæņāüĻĖēņ×É" : "Upper-Intermediate", emoji: "ŌŁ?, color: "from-indigo-500 to-indigo-700", startLvl: 60 };
        return { level: "C1+", label: lang === 'ko' ? "Ļ│ĀĻĖē?? : "Advanced", emoji: "?Åå", color: "from-purple-500 to-purple-700", startLvl: 100 };
