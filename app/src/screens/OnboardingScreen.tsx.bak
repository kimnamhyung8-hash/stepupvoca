    const [isCheckingNickname, setIsCheckingNickname] = useState(false);
    const [nicknameError, setNicknameError] = useState('');
    const [isNicknameValid, setIsNicknameValid] = useState(false);
    const [isSyncing, setIsSyncing] = useState(false);

    const lang = settings.lang || 'ko';

    const languages = [
        { code: 'ko', label: '?£ĻĄŁ??, flag: '?ć░?ćĘ' },
        { code: 'ja', label: '?źµ£¼Ķ¬?, flag: '?ć»?ćĄ' },
        { code: 'zh', label: 'ń«ĆõĮōõĖŁ??, flag: '?ć©?ć│' },
        { code: 'zh-TW', label: 'ń╣üķ½öõĖ?¢ć', flag: '?▒ń©▒' },
        { code: 'vi', label: 'Tiß║┐ng Viß╗ćt', flag: '?ć╗?ć│' },
        { code: 'en', label: 'English', flag: '?īÉ' }
    ];

    const steps = {
        ko: ["?Ėņ¢┤ ?ĀĒāØ", "ļ¦×ņČż ?Ģļ│┤", "?łļ▓© ?īņŖż??, "Ļ▓░Ļ│╝ ?ĢņØĖ", "?äļĪ£???żņĀĢ"],
        en: ["Language", "Goal/Age", "Mini Quiz", "Your Level", "Profile"]
    };

    const currentSteps = steps[lang as keyof typeof steps] || steps.en;

    const startLevelTest = () => {
        // Generate dummy words for the test in snippet, usually mock from vocaDB
        // For now, let's just bypass or use mock data
        setQuizWords([
            { word: 'Apple', meaning: '?¼Ļ│╝', answer_index: 0, options: ['?¼Ļ│╝', '?¼ļÅä', '?śļ░Ģ', 'ņ░ĖņÖĖ'] },
            { word: 'Challenge', meaning: '?äņĀä', answer_index: 1, options: ['?▒Ļ│Ą', '?äņĀä', '?żĒī©', '?£ņ×æ'] },
            { word: 'Persistent', meaning: '?łĻĖ░?łļŖö', answer_index: 2, options: ['ļ╣ĀļźĖ', '?Éļ”░', '?łĻĖ░?łļŖö', '?öļé£'] },
            { word: 'Sophisticated', meaning: '?ĖļĀ©??, answer_index: 3, options: ['?©ņł£??, 'ļ│Ąņ×Ī??, 'Ļ▒░ņ╣£', '?ĖļĀ©??] },
            { word: 'Innovation', meaning: '?üņŗĀ', answer_index: 0, options: ['?üņŗĀ', '?äĒåĄ', '?īĻ┤┤', 'ņ░ĮņĪ░'] }
        ]);
        setQuizIdx(0);
        setCorrectCount(0);
        setStep(2);
    };

    const handleLanguageSelect = (code: string) => {
        setSettings({ ...settings, lang: code });
