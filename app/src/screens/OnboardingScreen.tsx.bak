    const handleComplete = async () => {
        setIsSyncing(true);
        const result = getResult();
        const finalNickname = nickname.trim() || `VocaUser${Math.floor(Math.random() * 9999)}`;
        const finalUserInfo = { ...userInfo, nickname: finalNickname, level: result.level };

        setUserInfo(finalUserInfo);
        setCurrentLevel(result.startLvl);

        try {
            localStorage.setItem('vq_user', JSON.stringify(finalUserInfo));
            localStorage.setItem('vq_level', result.startLvl.toString());

            if (firebaseUser?.uid) {
                // Re-implement the sync logic or call the service
                // await syncUserToFirestore(firebaseUser.uid, { ...finalUserInfo, points: userPoints, equippedSkin, lang });
            }
            setScreet('HOME');
        } catch (e) {
            console.error(e);
            setScreet('HOME');
        } finally {
            setIsSyncing(false);
        }
    };

    return (
        <div className="screen bg-[#F8FAFF] flex flex-col overflow-hidden select-none">
