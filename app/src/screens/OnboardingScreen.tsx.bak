import { checkNicknameAvailable, syncUserToFirestore } from '../userService'; // Reconstructed service calls

interface OnboardingScreenProps {
    settings: any;
    setSettings: (s: any) => void;
    setScreen: (s: string) => void;
    userInfo: any;
    setUserInfo: (u: any) => void;
    firebaseUser: any;
    setCurrentLevel: (l: number) => void;
    userPoints: number;
    equippedSkin: string;
}

export const OnboardingScreen: React.FC<OnboardingScreenProps> = ({
    settings,
    setSettings,
    setScreen,
    userInfo,
    setUserInfo,
    firebaseUser,
