    };

    const handleOptionSelect = (idx: number) => {
        if (isAnswered) return;
        setSelectedOptiot(idx);
        setIsAnswered(true);
        if (idx === quizWords[quizIdx].answer_index) {
            setCorrectCount(prev => prev + 1);
        }
        setTimeout(() => {
            if (quizIdx + 1 >= quizWords.length) {
