
import React, { useState } from 'react';
import {
    ChevronLeft,
    User,
    Settings as SettingsIcon,
    LogOut,
    Mail,
    ShieldCheck,
    Coins,
    Crown,
    BookOpen,
    MessageSquare,
    ChevronRight,
    Info,
    ShieldAlert,
    HelpCircle,
    FileText
} from 'lucide-react';
import { t } from '../i18n';
import { decryptApiKey, encryptApiKey } from '../apiUtils';

interface ProfileScreenProps {
    settings: any;
    setScreen: (s: string) => void;
    userPoints: number;
    currentLevel: number;
    equippedSkin: string;
    userInfo: any;
    setUserInfo: (u: any) => void;
    firebaseUser: any;
    isPremium: boolean;
}

export const ProfileScreen: React.FC<ProfileScreenProps> = ({
    settings,
    setScreen,
    userPoints,
    currentLevel,
    equippedSkin,
    userInfo,
    setUserInfo,
    firebaseUser,
    isPremium
}) => {
    const lang = settings.lang || 'ko';
    const skins: Record<string, string> = {
        default: "?��",
        ninja: "?��",
        wizard: "?��?�♂�?,
        king: "?��",
        dragon: "?��",
        alien: "?��",
        robot: "?��"
    };

    const handleLogout = async () => {
        // Call firebase sign out
        setScreen('LOGIN');
    };

    const resetStudyInfo = () => {
        if (confirm(t(lang, "reset_confirm") || "Reset your study preferences?")) {
            setScreen('ONBOARDING');
        }
    };

    return (
        <div className="screen animate-fade-in bg-slate-50 flex flex-col font-sans">
            <header className="flex items-center justify-between px-4 py-4 bg-slate-900 text-white z-20 shrink-0">
                <button onClick={() => setScreen('HOME')} className="bg-white/10 hover:bg-white/20 text-white rounded-full p-2.5 active:scale-90 transition-all backdrop-blur-md">
                    <ChevronLeft size={20} />
                </button>
                <h2 className="text-lg font-black tracking-tight italic uppercase">{t(lang, "my_profile") || "My Profile"}</h2>
                <div className="w-10"></div>
            </header>

            <div className="flex-1 overflow-y-auto">
                <div className="bg-slate-900 px-8 pt-4 pb-14 rounded-b-[50px] text-center shrink-0 shadow-[0_15px_30px_rgba(0,0,0,0.1)]">
                    <div className="w-24 h-24 bg-white rounded-[32px] flex items-center justify-center text-6xl border-2 border-white/20 shadow-inner mx-auto mb-4 backdrop-blur-md cursor-pointer active:scale-90 transition-transform">
                        {skins[equippedSkin] || "?��"}
                    </div>
                    <h3 className="text-white text-xl font-black italic tracking-tight mb-1 uppercase">
                        {userInfo?.nickname || "Voca Warrior"}
                    </h3>
                    <p className="text-slate-400 text-[11px] font-bold leading-relaxed mb-6">
                        LV. {currentLevel} ??{firebaseUser?.email || "Guest"}
                    </p>
                    <div className="flex gap-3 max-w-[280px] mx-auto">
                        <div className="flex-1 bg-white/10 rounded-2xl p-3 border border-white/10 backdrop-blur-md">
                            <p className="text-[9px] font-black text-white/40 uppercase mb-1">{t(lang, "owned_points") || "Points"}</p>
                            <p className="text-sm font-black text-white flex items-center justify-center gap-1.5">
                                <Coins size={14} className="text-yellow-400" /> {userPoints.toLocaleString()}
                            </p>
                        </div>
                        <div className="flex-1 bg-white/10 rounded-2xl p-3 border border-white/10 backdrop-blur-md">
                            <p className="text-[9px] font-black text-white/40 uppercase mb-1">{t(lang, "purpose") || "Target"}</p>
                            <p className="text-sm font-black text-white truncate px-1">{userInfo?.purpose || "Active"}</p>
                        </div>
                    </div>
                </div>

                <div className="px-4 -mt-8 pb-32 space-y-8">
                    {/* Study Settings */}
                    <section className="space-y-4">
                        <div className="flex items-center gap-2 mb-1">
                            <div className="w-1.5 h-4 bg-indigo-500 rounded-full"></div>
                            <h3 className="text-slate-800 font-black text-sm tracking-tight">{t(lang, "my_study_settings") || "Study Settings"}</h3>
                        </div>

                        <div className="bg-white rounded-[32px] overflow-hidden divide-y divide-slate-50 border border-slate-100 shadow-sm">
                            <div className="flex justify-between items-center p-5">
                                <span className="text-slate-600 font-bold">{t(lang, "age") || "Age"}</span>
                                <span className="text-slate-800 font-black bg-slate-50 px-4 py-1.5 rounded-xl border border-slate-100 text-sm">{userInfo?.age || "N/A"}</span>
                            </div>
                            <div className="flex justify-between items-center p-5">
                                <span className="text-slate-600 font-bold">{t(lang, "eng_level") || "Level"}</span>
                                <span className="text-slate-800 font-black bg-slate-50 px-4 py-1.5 rounded-xl border border-slate-100 text-sm">{userInfo?.level || "N/A"}</span>
                            </div>
                            <button onClick={resetStudyInfo} className="w-full flex justify-between items-center p-5 hover:bg-slate-50 active:bg-slate-100 transition-all text-left group">
                                <span className="text-indigo-600 font-black">{t(lang, "reset_info") || "Reset Assessment"}</span>
                                <ChevronRight size={18} className="text-slate-300 group-hover:text-indigo-600 transition-colors" />
                            </button>
                        </div>
                    </section>

                    {/* AI Settings */}
                    <section className="space-y-4">
                        <div className="flex items-center gap-2 mb-1">
                            <div className="w-1.5 h-4 bg-indigo-500 rounded-full"></div>
                            <h3 className="text-slate-800 font-black text-sm tracking-tight">{t(lang, "ai_settings") || "AI Settings"}</h3>
                        </div>
                        <div className="bg-white rounded-[32px] overflow-hidden p-6 space-y-3 border border-slate-100 shadow-sm">
                            <label className="text-slate-600 font-bold block text-[10px] uppercase tracking-widest">Gemini API Key</label>
                            <input
                                type="password"
                                defaultValue={decryptApiKey(localStorage.getItem('vq_gemini_key') || '')}
                                onBlur={(e) => localStorage.setItem('vq_gemini_key', encryptApiKey(e.target.value))}
                                className="w-full bg-slate-50 border border-slate-100 rounded-xl px-4 py-3 text-sm focus:border-indigo-400 outline-none transition-all font-bold"
                                placeholder="Enter Gemini API Key"
                            />
                            <p className="text-[10px] text-slate-400 font-medium italic">Used for AI pronunciation & analysis</p>
                        </div>
                    </section>

                    {/* Account & Support */}
                    <section className="space-y-4">
                        <div className="flex items-center gap-2 mb-1">
                            <div className="w-1.5 h-4 bg-emerald-500 rounded-full"></div>
                            <h3 className="text-slate-800 font-black text-sm tracking-tight">{t(lang, "account_system") || "System"}</h3>
                        </div>
                        <div className="bg-white rounded-[32px] overflow-hidden divide-y divide-slate-50 border border-slate-100 shadow-sm">
                            <button onClick={handleLogout} className="w-full flex justify-between items-center p-5 hover:bg-slate-50 transition-all group">
                                <span className="text-red-500 font-black">{firebaseUser ? "Log Out" : "Log In"}</span>
                                <LogOut size={18} className="text-red-200 group-hover:text-red-500" />
                            </button>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    );
};
